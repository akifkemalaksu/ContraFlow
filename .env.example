# Bu dosyayı kopyalayıp ilgili ortam dosyasına dönüştür:
#   cp .env.example .env.development   → local geliştirme
#   cp .env.example .env.docker        → docker compose
#   cp .env.example .env.staging       → staging
#   cp .env.example .env.production    → production
#
# Uygulama hangi dosyayı yükleyeceğini ENVIRONMENT env var'ından belirler:
#   ENVIRONMENT=development  →  .env.development  (varsayılan)
#   ENVIRONMENT=docker       →  .env.docker
#   ENVIRONMENT=staging      →  .env.staging
#   ENVIRONMENT=production   →  .env.production

APP_NAME=ContraFlow
ENVIRONMENT=development
DEBUG=false

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/contraflow
REDIS_URL=redis://HOST:6379/0

# openssl rand -hex 32
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# openssl rand -hex 32
API_KEY_SECRET=
API_KEY_PREFIX_LENGTH=8

# openssl rand -hex 32
WALLET_ENCRYPTION_KEY=

ALLOWED_ORIGINS=["http://localhost:3000"]

# Hyperliquid
HYPERLIQUID_USE_TESTNET=true
