APP_NAME=ContraFlow
ENVIRONMENT=staging
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/contraflow_staging
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=staging-secret-key-replace-before-use
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

API_KEY_SECRET=staging-api-key-secret-replace-before-use
API_KEY_PREFIX_LENGTH=8

ALLOWED_ORIGINS=["https://staging.example.com"]
