APP_NAME=ContraFlow
ENVIRONMENT=production
DEBUG=false
SEED_ON_STARTUP=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/contraflow_prod
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=production-secret-key-replace-before-use
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

API_KEY_SECRET=production-api-key-secret-replace-before-use
API_KEY_PREFIX_LENGTH=8

ALLOWED_ORIGINS=["https://example.com"]

# Hyperliquid
HYPERLIQUID_USE_TESTNET=false
